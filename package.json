{
  "name": "hardtry",
  "version": "0.0.0",
  "description": "A better try-catch",
  "keywords": [
    "abort-signal",
    "error-handling",
    "retry",
    "timeout",
    "try-catch"
  ],
  "homepage": "https://github.com/adelrodriguez/hardtry#readme",
  "bugs": {
    "url": "https://github.com/adelrodriguez/hardtry/issues"
  },
  "license": "MIT",
  "author": "Adel Rodríguez",
  "repository": {
    "type": "git",
    "url": "https://github.com/adelrodriguez/hardtry.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    }
  },
  "scripts": {
    "build": "bunup",
    "bump:deps": "bun update --interactive",
    "check": "adamantite check",
    "dev": "bunup --watch",
    "fix": "adamantite fix",
    "release": "changeset publish",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "typecheck": "adamantite typecheck",
    "version": "changeset version && bun run format",
    "format": "adamantite format",
    "analyze": "adamantite analyze"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@clack/prompts": "1.0.1",
    "@types/bun": "1.3.9",
    "adamantite": "^0.29.1",
    "bunup": "0.16.29",
    "knip": "5.85.0",
    "oxfmt": "0.34.0",
    "oxlint": "1.49.0",
    "oxlint-tsgolint": "0.14.2",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.1"
}
